#!/usr/bin/env python3
"""brain-index — build a local semantic-search index over the my-brain markdown wiki.

Walks every .md file (skips files starting with `_` and anything under .git/),
chunks by markdown heading (falling back to ~500-token windows for big sections),
computes embeddings LOCALLY, and stores vectors + metadata in
~/projects/my-brain/.index/brain.db using sqlite-vec.

Embeddings NEVER leave the machine:
  1. Ollama (http://localhost:11434, model `nomic-embed-text`) if reachable.
  2. sentence-transformers (all-MiniLM-L6-v2) as a local fallback.
If neither is available the script exits with a clear message.

Incremental: files whose sha256 is unchanged since the last run are skipped.
Use `--full` to force a complete rebuild.

Usage:
    brain-index            # incremental index
    brain-index --full     # wipe and rebuild
    brain-index -v         # verbose
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sqlite3
import sys
import urllib.error
import urllib.request
from pathlib import Path

BRAIN_ROOT = Path(__file__).resolve().parent.parent
INDEX_DIR = BRAIN_ROOT / ".index"
DB_PATH = INDEX_DIR / "brain.db"

OLLAMA_URL = os.environ.get("OLLAMA_URL", "http://localhost:11434")
OLLAMA_MODEL = os.environ.get("BRAIN_OLLAMA_MODEL", "nomic-embed-text")
ST_MODEL = os.environ.get("BRAIN_ST_MODEL", "all-MiniLM-L6-v2")

# Roughly 4 chars per token; ~500 tokens ≈ 2000 chars.
MAX_CHUNK_CHARS = 2000

# Directories to skip entirely (relative to BRAIN_ROOT).
SKIP_DIRS = {".git", ".index", ".obsidian"}


# --------------------------------------------------------------------------- #
# Embedding backends (both fully local)
# --------------------------------------------------------------------------- #
class EmbeddingError(RuntimeError):
    pass


def _ollama_available() -> bool:
    try:
        req = urllib.request.Request(f"{OLLAMA_URL}/api/tags")
        with urllib.request.urlopen(req, timeout=2) as resp:
            data = json.loads(resp.read().decode("utf-8"))
        names = {m.get("name", "").split(":")[0] for m in data.get("models", [])}
        return OLLAMA_MODEL.split(":")[0] in names or bool(names)
    except Exception:
        return False


def _ollama_embed(texts: list[str]) -> list[list[float]]:
    out = []
    for t in texts:
        payload = json.dumps({"model": OLLAMA_MODEL, "prompt": t}).encode("utf-8")
        req = urllib.request.Request(
            f"{OLLAMA_URL}/api/embeddings",
            data=payload,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=60) as resp:
            data = json.loads(resp.read().decode("utf-8"))
        emb = data.get("embedding")
        if not emb:
            raise EmbeddingError(f"Ollama returned no embedding (model {OLLAMA_MODEL}).")
        out.append(emb)
    return out


_ST_MODEL_OBJ = None


def _st_available() -> bool:
    try:
        import sentence_transformers  # noqa: F401

        return True
    except Exception:
        return False


def _st_embed(texts: list[str]) -> list[list[float]]:
    global _ST_MODEL_OBJ
    if _ST_MODEL_OBJ is None:
        from sentence_transformers import SentenceTransformer

        _ST_MODEL_OBJ = SentenceTransformer(ST_MODEL)
    vecs = _ST_MODEL_OBJ.encode(texts, normalize_embeddings=True)
    return [list(map(float, v)) for v in vecs]


def pick_backend(verbose: bool = False):
    """Return (name, embed_fn). Raises SystemExit if none available."""
    if _ollama_available():
        if verbose:
            print(f"[embed] using Ollama ({OLLAMA_MODEL}) at {OLLAMA_URL}")
        return f"ollama:{OLLAMA_MODEL}", _ollama_embed
    if _st_available():
        if verbose:
            print(f"[embed] Ollama not reachable; using sentence-transformers ({ST_MODEL})")
        return f"sentence-transformers:{ST_MODEL}", _st_embed
    sys.exit(
        "ERROR: no local embedding backend available.\n"
        "  Option A (recommended): install & run Ollama, then\n"
        f"      ollama pull {OLLAMA_MODEL}\n"
        "  Option B: pip install sentence-transformers\n"
        "See docs/semantic-search.md for details."
    )


# --------------------------------------------------------------------------- #
# Markdown walking / chunking
# --------------------------------------------------------------------------- #
def iter_md_files():
    for path in BRAIN_ROOT.rglob("*.md"):
        rel = path.relative_to(BRAIN_ROOT)
        if any(part in SKIP_DIRS for part in rel.parts):
            continue
        if any(part.startswith("_") for part in rel.parts):
            continue
        yield path


FRONTMATTER_RE = re.compile(r"^---\n.*?\n---\n", re.DOTALL)
HEADING_RE = re.compile(r"^(#{1,6})\s+(.*)$", re.MULTILINE)


def strip_frontmatter(text: str) -> str:
    return FRONTMATTER_RE.sub("", text, count=1)


def _split_long(text: str) -> list[str]:
    """Split an over-long block into ~MAX_CHUNK_CHARS pieces on paragraph breaks."""
    if len(text) <= MAX_CHUNK_CHARS:
        return [text]
    parts, buf = [], ""
    for para in text.split("\n\n"):
        if buf and len(buf) + len(para) + 2 > MAX_CHUNK_CHARS:
            parts.append(buf.strip())
            buf = para
        else:
            buf = f"{buf}\n\n{para}" if buf else para
    if buf.strip():
        parts.append(buf.strip())
    return parts


def chunk_markdown(text: str):
    """Yield (heading, chunk_text) split on markdown headings, big blocks subdivided."""
    body = strip_frontmatter(text)
    matches = list(HEADING_RE.finditer(body))
    if not matches:
        for piece in _split_long(body.strip()):
            if piece:
                yield ("", piece)
        return

    # Preamble before first heading.
    pre = body[: matches[0].start()].strip()
    if pre:
        for piece in _split_long(pre):
            yield ("", piece)

    for i, m in enumerate(matches):
        heading = m.group(2).strip()
        start = m.start()
        end = matches[i + 1].start() if i + 1 < len(matches) else len(body)
        section = body[start:end].strip()
        if not section:
            continue
        for piece in _split_long(section):
            yield (heading, piece)


def file_hash(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


# --------------------------------------------------------------------------- #
# DB
# --------------------------------------------------------------------------- #
def connect(dim: int):
    import sqlite_vec

    db = sqlite3.connect(DB_PATH)
    db.enable_load_extension(True)
    sqlite_vec.load(db)
    db.enable_load_extension(False)
    db.execute(
        "CREATE TABLE IF NOT EXISTS files ("
        " path TEXT PRIMARY KEY, hash TEXT NOT NULL)"
    )
    db.execute(
        "CREATE TABLE IF NOT EXISTS chunks ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " path TEXT NOT NULL, heading TEXT, text TEXT NOT NULL)"
    )
    db.execute(
        f"CREATE VIRTUAL TABLE IF NOT EXISTS vec_chunks USING vec0("
        f" chunk_id INTEGER PRIMARY KEY, embedding FLOAT[{dim}])"
    )
    db.execute(
        "CREATE TABLE IF NOT EXISTS meta (key TEXT PRIMARY KEY, value TEXT)"
    )
    return db


def get_meta(db, key):
    row = db.execute("SELECT value FROM meta WHERE key=?", (key,)).fetchone()
    return row[0] if row else None


def set_meta(db, key, value):
    db.execute(
        "INSERT INTO meta(key,value) VALUES(?,?) "
        "ON CONFLICT(key) DO UPDATE SET value=excluded.value",
        (key, str(value)),
    )


def delete_file_chunks(db, rel_path):
    ids = [
        r[0]
        for r in db.execute("SELECT id FROM chunks WHERE path=?", (rel_path,)).fetchall()
    ]
    for cid in ids:
        db.execute("DELETE FROM vec_chunks WHERE chunk_id=?", (cid,))
    db.execute("DELETE FROM chunks WHERE path=?", (rel_path,))
    db.execute("DELETE FROM files WHERE path=?", (rel_path,))


# --------------------------------------------------------------------------- #
# Main
# --------------------------------------------------------------------------- #
def serialize(vec) -> bytes:
    import sqlite_vec

    return sqlite_vec.serialize_float32(vec)


def main() -> int:
    ap = argparse.ArgumentParser(description="Index my-brain markdown for semantic search.")
    ap.add_argument("--full", action="store_true", help="force full reindex")
    ap.add_argument("-v", "--verbose", action="store_true")
    args = ap.parse_args()

    try:
        import sqlite_vec  # noqa: F401
    except ImportError:
        sys.exit(
            "ERROR: sqlite-vec not installed.\n"
            "  pip install -r requirements-search.txt   (or: pip install sqlite-vec)"
        )

    backend_name, embed = pick_backend(args.verbose)

    # Probe embedding dimension with a tiny call.
    dim = len(embed(["dimension probe"])[0])
    if args.verbose:
        print(f"[embed] backend={backend_name} dim={dim}")

    INDEX_DIR.mkdir(parents=True, exist_ok=True)

    if args.full and DB_PATH.exists():
        DB_PATH.unlink()

    db = connect(dim)

    # If backend/dim changed, force full rebuild to avoid mixing vector spaces.
    prev_backend = get_meta(db, "backend")
    if prev_backend and prev_backend != backend_name:
        print(f"[index] backend changed ({prev_backend} -> {backend_name}); rebuilding.")
        db.close()
        DB_PATH.unlink()
        db = connect(dim)
    set_meta(db, "backend", backend_name)
    set_meta(db, "dim", dim)

    known = {r[0]: r[1] for r in db.execute("SELECT path, hash FROM files").fetchall()}
    seen = set()
    n_files = n_chunks = n_skipped = 0

    for path in iter_md_files():
        rel = str(path.relative_to(BRAIN_ROOT))
        seen.add(rel)
        text = path.read_text(encoding="utf-8", errors="replace")
        h = file_hash(text)
        if known.get(rel) == h:
            n_skipped += 1
            continue

        # Changed or new -> re-chunk.
        delete_file_chunks(db, rel)
        chunks = [(hd, tx) for hd, tx in chunk_markdown(text) if tx.strip()]
        if not chunks:
            db.execute("INSERT INTO files(path, hash) VALUES(?,?)", (rel, h))
            continue

        vectors = embed([tx for _, tx in chunks])
        for (heading, tx), vec in zip(chunks, vectors):
            cur = db.execute(
                "INSERT INTO chunks(path, heading, text) VALUES(?,?,?)",
                (rel, heading, tx),
            )
            cid = cur.lastrowid
            db.execute(
                "INSERT INTO vec_chunks(chunk_id, embedding) VALUES(?,?)",
                (cid, serialize(vec)),
            )
            n_chunks += 1
        db.execute("INSERT INTO files(path, hash) VALUES(?,?)", (rel, h))
        n_files += 1
        if args.verbose:
            print(f"[index] {rel}: {len(chunks)} chunks")

    # Prune deleted files.
    for rel in list(known):
        if rel not in seen:
            delete_file_chunks(db, rel)
            if args.verbose:
                print(f"[index] removed (deleted file): {rel}")

    db.commit()
    total = db.execute("SELECT COUNT(*) FROM chunks").fetchone()[0]
    db.close()
    print(
        f"Indexed {n_files} changed file(s), {n_chunks} new chunk(s); "
        f"{n_skipped} unchanged. Total chunks in db: {total}."
    )
    print(f"DB: {DB_PATH}  |  backend: {backend_name}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
